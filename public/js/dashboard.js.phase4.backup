// Initialization
(async function init() {
    // CRÍTICO: Esperar a que AppState esté disponible
    if (typeof AppState === 'undefined') {
        console.warn('[INIT] AppState no disponible, esperando...');
        await new Promise(resolve => {
            const checkInterval = setInterval(() => {
                if (typeof AppState !== 'undefined') {
                    clearInterval(checkInterval);
                    console.log('[INIT] ✅ AppState disponible');
                    resolve();
                }
            }, 50);
        });
    }

    // Inicializar token y eventId desde storage (AHORA AppState está disponible)
    if (sessionStorage.getItem('token') || localStorage.getItem('token')) {
        window.currentToken = sessionStorage.getItem('token') || localStorage.getItem('token');
        console.log('[INIT] Token restaurado desde storage');
    }
    if (sessionStorage.getItem('eventId') || localStorage.getItem('eventId')) {
        window.currentEventId = sessionStorage.getItem('eventId') || localStorage.getItem('eventId');
        console.log('[INIT] EventId restaurado desde storage:', window.currentEventId);
    }

    console.log('[INIT] Token:', currentToken ? 'Presente' : 'FALTANTE', 'Event:', currentEventId || 'FALTANTE');
    
    if (enforceSessionTimeout()) return;
    touchActivity();
    bindSessionActivity();
    
    const authed = await checkAuth();
    if (authed) {
        console.log('[INIT] ✅ Auth exitosa. currentEventId:', currentEventId);
        await loadDashboard();
        console.log('[INIT] ✅ Dashboard cargado');
    } else {
        console.error('[INIT] Auth falló. Redirigiendo a login.');
        // Ensure redirect happens
        setTimeout(() => {
            window.location.href = '/';
        }, 1000);
    }
})();
