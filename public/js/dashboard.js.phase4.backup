const SESSION_TIMEOUT_MS = 30 * 60 * 1000;
const LAST_ACTIVITY_KEY = 'lastActivity';

// ===================================
// SESSION MANAGEMENT WRAPPERS → Helpers
// ===================================
function touchActivity() {
    if (typeof Helpers === 'undefined' || !Helpers.touchActivity) return;
    return Helpers.touchActivity();
}

function isSessionExpired() {
    if (typeof Helpers === 'undefined' || !Helpers.isSessionExpired) return false;
    return Helpers.isSessionExpired();
}

function enforceSessionTimeout() {
    if (!currentToken) return false;
    if (isSessionExpired()) {
        localStorage.removeItem('token');
        localStorage.removeItem('role');
        localStorage.removeItem('eventId');
        localStorage.removeItem('username');
        sessionStorage.removeItem('token');
        sessionStorage.removeItem('role');
        sessionStorage.removeItem('eventId');
        sessionStorage.removeItem('username');
        window.location.href = '/';
        return true;
    }
    return false;
}

function bindSessionActivity() {
    ['mousemove', 'keydown', 'click', 'touchstart'].forEach(evt => {
        document.addEventListener(evt, touchActivity, { passive: true });
    });
}

// ===================================
// UTILITIES WRAPPERS → Helpers
// ===================================
function getBogotaLocalidades() {
    if (typeof Helpers === 'undefined' || !Helpers.getBogotaLocalidades) {
        return AppState.constants.BOGOTA_LOCALIDADES || [];
    }
    return Helpers.getBogotaLocalidades();
}

