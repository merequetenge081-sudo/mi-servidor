{
  "name": "mi-servidor",
  "version": "2.0.0",
  "description": "Sistema de gestión electoral enterprise - Fase 1 Refactorización",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --no-coverage --passWithNoTests",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --watch --passWithNoTests",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --testPathPattern=unit --passWithNoTests",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --testPathPattern=integration --passWithNoTests",
    "test:e2e": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --testPathPattern=e2e --passWithNoTests",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --coverage --passWithNoTests",
    "test:services": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --testPathPattern=services --coverage",
    "test:controllers": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --testPathPattern=controllers --coverage",
    "test:all": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --coverage --verbose",
    "test:ci": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --coverage --ci --maxWorkers=2",
    "test:report": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testEnvironment=node --coverage",
    "docs:generate": "node --experimental-vm-modules scripts/generateTestDocs.js",
    "report:json": "node --experimental-vm-modules scripts/generateTestReport.js",
    "report:dashboard": "node --experimental-vm-modules scripts/generateDashboard.js",
    "report:view": "node --experimental-vm-modules scripts/generateDashboard.js && start reports/dashboard.html",
    "docs:auto": "npm run test && npm run docs:generate",
    "report:full": "npm run test && npm run report:json && npm run report:dashboard && npm run docs:generate",
    "lint": "eslint src --fix"
  },
  "keywords": [
    "electoral",
    "management",
    "enterprise",
    "express",
    "mongodb"
  ],
  "author": "Development Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^5.9.0",
    "mongoose": "^7.6.1",
    "pdfkit": "^0.13.0",
    "qrcode": "^1.5.3",
    "resend": "^0.16.0",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-repo/mi-servidor"
  }
}
